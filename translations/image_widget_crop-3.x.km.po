msgid "Title"
msgstr "бһ…бҹҶбһҺбһ„вҖӢбһҮбһҫбһ„"
msgid "Body"
msgstr "бһҸбһҪ"
msgid "Image"
msgstr "бһҡбһјбһ”вҖӢбһ—бһ¶бһ–"
msgid "Width"
msgstr "бһ‘бһ‘бһ№бһ„"
msgid "Height"
msgstr "бһҖбһҳбҹ’бһ–бһҹбҹӢ"
msgid "Media"
msgstr "бһҳбҹҒбһҢбҹҖ"
msgid "About"
msgstr "бһўбҹҶбһ–бһё"
msgid "Progress indicator"
msgstr "бһ‘бҹ’бһҡбһ“бһ·бһ…вҖӢбһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһңбһҢбҹ’бһҚбһ“бһ—бһ¶бһ–"
msgid "Preview image style"
msgstr "бһҳбһҫбһӣвҖӢбһҡбһ…бһ“бһ¶бһ”бҹҗбһ‘бҹ’бһҳвҖӢбһҡбһјбһ”бһ—бһ¶бһ–вҖӢбһҮбһ¶вҖӢбһҳбһ»бһ“"
msgid "no preview"
msgstr "бһӮбҹ’бһҳбһ¶бһ“вҖӢбһҖбһ¶бһҡвҖӢбһҳбһҫбһӣвҖӢбһҮбһ¶вҖӢбһҳбһ»бһ“"
msgid "The preview image will be shown while editing the content."
msgstr ""
"бһҖбһ¶бһҡвҖӢбһҳбһҫбһӣвҖӢбһҡбһјбһ”бһ—бһ¶бһ–вҖӢбһҮбһ¶вҖӢбһҳбһ»бһ“вҖӢбһ“бһ№бһ„вҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ”бһ„бҹ’бһ бһ¶бһүвҖӢ "
"бһҒбһҺбҹҲвҖӢбһ–бҹҒбһӣвҖӢбһҖбҹҶбһ–бһ»бһ„вҖӢбһҖбҹӮвҖӢбһҹбһҳбҹ’бһҡбһҪбһӣвҖӢбһҳбһ¶бһҸбһ·бһҖбһ¶ "
"бҹ”"
