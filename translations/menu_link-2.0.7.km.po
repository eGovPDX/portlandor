msgid "Title"
msgstr "бһ…бҹҶбһҺбһ„вҖӢбһҮбһҫбһ„"
msgid "Value"
msgstr "бһҸбһҳбҹ’бһӣбҹғ"
msgid "Description"
msgstr "бһҹбҹҒбһ…бһҖбҹ’бһҠбһёвҖӢбһ–бһ·бһ–бһҺбҹҢбһ“бһ¶"
msgid "Weight"
msgstr "бһ—бһ¶бһ–вҖӢбһҹбҹҶбһҒбһ¶бһ“бҹӢ"
msgid "Parent"
msgstr "бһҳбҹҒ"
msgid "Menu"
msgstr "бһҳбҹүбһәбһ“бһ»бһҷ"
msgid "Parent item"
msgstr "бһ’бһ¶бһҸбһ»вҖӢбһҳбҹҒ"
msgid "Menu link"
msgstr "бһҸбҹҶбһҺвҖӢбһҳбҹүбһәбһ“бһ»бһҷ"
msgid "Menu settings"
msgstr "бһҖбһ¶бһҡбһҖбҹҶбһҺбһҸбҹӢвҖӢбһҳбҹүбһәбһ“бһ»бһҷвҖӢ"
msgid "Default value"
msgstr "бһҸбһҳбҹ’бһӣбҹғвҖӢбһӣбҹҶбһ“бһ¶бҹҶбһҠбһҫбһҳ"
msgid "Menu link title"
msgstr "бһ…бҹҶбһҺбһ„бһҮбһҫбһ„вҖӢбһҸбҹҶбһҺвҖӢбһҳбҹүбһәбһ“бһ»бһҷ"
msgid "Menu name"
msgstr "бһҲбҹ’бһҳбҹ„бҹҮвҖӢбһҳбҹүбһәбһ“бһ»бһҷвҖӢ"
msgid "Not in menu"
msgstr "бһҳбһ·бһ“вҖӢбһҳбҹӮбһ“вҖӢбһ“бҹ…вҖӢбһҖбҹ’бһ“бһ»бһ„вҖӢбһҳбҹүбһәбһ“бһ»бһҷ"
msgid "Text format"
msgstr "бһ‘бҹ’бһҡбһ„бҹӢвҖӢбһ‘бҹ’бһҡбһ¶бһҷвҖӢбһўбһҸбҹ’бһҗбһ”бһ‘"
msgid "Provide a menu link"
msgstr "бһ•бҹ’бһҸбһӣбҹӢвҖӢбһҸбҹҶбһҺвҖӢбһҳбҹүбһәбһ“бһ»бһҷ"
msgid "Available menus"
msgstr "бһҳбҹүбһәбһ“бһ»бһҷвҖӢбһҠбҹӮбһӣвҖӢбһўбһ¶бһ…вҖӢбһҡбһҖвҖӢбһ”бһ¶бһ“вҖӢ"
msgid "Shown when hovering over the menu link."
msgstr ""
"бһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһ“бҹ…вҖӢбһ–бҹҒбһӣвҖӢбһҠбҹӮбһӣвҖӢбһҠбһ¶бһҖбҹӢвҖӢбһҖбһҺбҹ’бһҠбһ»бһҡвҖӢбһ“бҹ…вҖӢбһӣбһҫвҖӢбһҸбҹҶбһҺвҖӢбһҳбҹүбһәбһ“бһ»бһҷ "
"бҹ”"
