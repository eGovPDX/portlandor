msgid "Delete"
msgstr "бһӣбһ»бһ”"
msgid "Operations"
msgstr "бһ”бҹ’бһҡбһҸбһ·бһ”бһҸбҹ’бһҸбһ·бһҖбһ¶бһҡ"
msgid "Action"
msgstr "бһўбҹҶбһ–бһҫ"
msgid "Edit"
msgstr "бһҖбҹӮбһҹбһҳбҹ’бһҡбһҪбһӣ"
msgid "View"
msgstr "бһҳбһҫбһӣ"
msgid "Revisions"
msgstr "бһҖбһ¶бһҡвҖӢбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһЎбһҫбһ„вҖӢбһңбһ·бһү"
msgid "No items selected."
msgstr "бһӮбҹ’бһҳбһ¶бһ“вҖӢбһ’бһ¶бһҸбһ»вҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһҮбҹ’бһҡбһҫбһҹВ бҹ”"
msgid "Create new revision"
msgstr "бһ”бһ„бҹ’бһҖбһҫбһҸвҖӢвҖӢбһҖбһ¶бһҡвҖӢбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһЎбһҫбһ„бһңбһ·бһүвҖӢбһҗбҹ’бһҳбһё"
msgid "Revert"
msgstr "бһҸбҹ’бһҡбһЎбһ”бҹӢвҖӢбһ‘бҹ…вҖӢбһҠбһҫбһҳ"
msgid "revert"
msgstr "бһҸбҹ’бһҡбһЎбһ”бҹӢвҖӢбһ‘бҹ…вҖӢбһҠбһҫбһҳвҖӢ"
msgid "Revision"
msgstr "бһҖбһ¶бһҡвҖӢбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһЎбһҫбһ„вҖӢбһңбһ·бһү"
msgid "Are you sure you want to revert to the revision from %revision-date?"
msgstr ""
"бһҸбһҫвҖӢбһўбҹ’бһ“бһҖвҖӢбһ”бҹ’бһҡбһ¶бһҖбһҠвҖӢбһҗбһ¶вҖӢбһўбҹ’бһ“бһҖвҖӢбһ…бһ„бҹӢвҖӢбһҠбһ¶бһҖбҹӢвҖӢбһҖбһ¶бһҡвҖӢбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһЎбһҫбһ„бһңбһ·бһүвҖӢбһҸбҹ’бһҡбһЎбһ”бҹӢвҖӢбһ‘бҹ…вҖӢбһҠбһҫбһҳвҖӢбһ–бһё "
"%revision-date бһ¬ ?"
msgid "Revision information"
msgstr "бһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһўбҹҶбһ–бһёвҖӢбһҖбһ¶бһҡвҖӢбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһЎбһҫбһ„вҖӢбһңбһ·бһү"
msgid "Copy of the revision from %date."
msgstr ""
"бһ…бҹ’бһ”бһ¶бһ”бҹӢвҖӢбһҗбһҸвҖӢбһ…бһҳбҹ’бһӣбһ„вҖӢбһ“бҹғвҖӢбһҖбһ¶бһҡвҖӢбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһЎбһҫбһ„вҖӢбһңбһ·бһүвҖӢбһ–бһё "
"%dateВ бҹ”"
msgid "@type: reverted %title revision %revision."
msgstr ""
"@typeВ бҹ– бһ”бһ¶бһ“вҖӢбһҸбҹ’бһҡбһЎбһ”бҹӢ %title "
"бһҖбһ¶бһҡвҖӢбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһЎбһҫбһ„вҖӢбһңбһ·бһү "
"%revisionВ бҹ”"
msgid "Revision log message"
msgstr "бһҹбһ¶бһҡвҖӢбһҖбҹҶбһҺбһҸбҹӢвҖӢбһ бҹҒбһҸбһ»вҖӢбһ“бҹғвҖӢбһҖбһ¶бһҡвҖӢбһ–бһ·бһ“бһ·бһҸбҹ’бһҷвҖӢбһЎбһҫбһ„вҖӢбһңбһ·бһү"
