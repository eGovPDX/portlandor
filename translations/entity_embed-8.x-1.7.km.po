msgid "Title"
msgstr "бһ…бҹҶбһҺбһ„вҖӢбһҮбһҫбһ„"
msgid "Next"
msgstr "бһ”бһ“бҹ’бһ‘бһ¶бһ”бҹӢ"
msgid "Description"
msgstr "бһҹбҹҒбһ…бһҖбҹ’бһҠбһёвҖӢбһ–бһ·бһ–бһҺбҹҢбһ“бһ¶"
msgid "File"
msgstr "бһҜбһҖбһҹбһ¶бһҡ"
msgid "None"
msgstr "бһӮбҹ’бһҳбһ¶бһ“"
msgid "Image"
msgstr "бһҡбһјбһ”вҖӢбһ—бһ¶бһ–"
msgid "Center"
msgstr "бһҖбһҺбҹ’бһҸбһ¶бһӣ"
msgid "Label"
msgstr "бһҹбҹ’бһӣбһ¶бһҖ"
msgid "Node"
msgstr "бһҗбҹ’бһ“бһ¶бҹҶбһ„"
msgid "Filters"
msgstr "бһҸбһҳбҹ’бһҡбһ„"
msgid "Left"
msgstr "бһҶбҹ’бһңбҹҒбһ„"
msgid "Right"
msgstr "бһҹбҹ’бһҸбһ¶бҹҶ"
msgid "Alternate text"
msgstr "бһўбһҸбҹ’бһҗбһ”бһ‘вҖӢбһҮбҹҶбһ“бһҪбһҹ"
msgid "About"
msgstr "бһўбҹҶбһ–бһё"
msgid "Uses"
msgstr "бһ”бҹ’бһҡбһҫ"
msgid ""
"This text will be used by screen readers, search engines, or when the "
"image cannot be loaded."
msgstr ""
"бһўбһҸбҹ’бһҗбһ”бһ‘вҖӢбһ“бҹҒбҹҮвҖӢбһ“бһ№бһ„вҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бҹ’бһҡбһҫвҖӢбһҠбҹ„бһҷвҖӢбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёвҖӢбһўбһ¶бһ“вҖӢбһўбҹҒбһҖбҹ’бһҡбһ„бҹӢвҖӢ "
"бһҳбҹүбһ¶бһҹбҹҠбһёбһ“вҖӢбһҹбҹ’бһңбҹӮбһ„вҖӢбһҡбһҖвҖӢ "
"бһ¬вҖӢбһ“бҹ…вҖӢбһ–бҹҒбһӣвҖӢбһҳбһ·бһ“вҖӢбһўбһ¶бһ…вҖӢбһ•бҹ’бһ‘бһ»бһҖвҖӢбһҡбһјбһ”вҖӢбһ—бһ¶бһ–вҖӢбһ”бһ¶бһ“вҖӢ "
"бҹ”"
msgid ""
"The title is used as a tool tip when the user hovers the mouse over "
"the image."
msgstr ""
"бһ…бҹҶбһҺбһ„вҖӢбһҮбһҫбһ„вҖӢбһ“бһ№бһ„вҖӢбһҸбҹ’бһҡбһјбһңвҖӢвҖӢбһ”бҹ’бһҡбһҫвҖӢбһҮбһ¶вҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһҮбҹҶбһ“бһҪбһҷ "
"бһ“бҹ…вҖӢбһ–бҹҒбһӣвҖӢбһўбҹ’бһ“бһҖвҖӢбһ”бҹ’бһҡбһҫвҖӢбһҹбҹҶбһҖбһ¶бҹҶбһ„вҖӢбһҖбһҺбҹ’бһҸбһ»бһҡвҖӢбһ“бҹ…вҖӢбһ–бһёвҖӢбһӣбһҫвҖӢбһҡбһјбһ”вҖӢбһ—бһ¶бһ–вҖӢ "
"бҹ”"
msgid "The description may be used as the label of the link to the file."
msgstr ""
"бһҹбҹҒбһ…бһҖбҹ’бһҸбһёвҖӢбһ–бһ·бһ–бһҺбҹҢбһ“бһ¶вҖӢбһўбһ¶бһ…вҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ”бҹ’бһҡбһҫвҖӢбһҮбһ¶вҖӢбһҹбҹ’бһӣбһ¶бһҖвҖӢбһ“бҹғвҖӢбһҸбҹҶбһҺвҖӢбһ‘бҹ…вҖӢбһҜбһҖбһҹбһ¶бһҡ "
"бҹ”"
