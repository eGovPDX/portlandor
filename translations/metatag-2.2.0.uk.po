msgstr "Мобільний Android: Маніфест"
msgid "Apple Mobile: iTunes App"
msgstr "Apple Mobile: додаток iTunes"
msgid "Apple Mobile: Web App Capable"
msgstr "Apple Mobile: Підтримка веб-додатків"
msgid "Apple Mobile: Web App Status bar color"
msgstr "Apple Mobile: Колір рядка стану веб-додатку"
msgid "Apple Mobile: Web App Title"
msgstr "Apple Mobile: Назва веб-додатку"
msgid "Mobile: Cleartype"
msgstr "Мобільний: Cleartype"
