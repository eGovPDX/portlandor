msgid "Development"
msgstr "бһҖбһ¶бһҡвҖӢбһўбһ—бһ·бһңбһҢбҹ’бһҚ"
msgid "@remote could not be saved to @path."
msgstr ""
"@remote "
"бһҳбһ·бһ“вҖӢбһўбһ¶бһ…вҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһҡбһҖбҹ’бһҹбһ¶бһ‘бһ»бһҖвҖӢбһ‘бҹ…бһҖбһ¶бһ“бҹӢ "
"@path бһ”бһ¶бһ“вҖӢбһЎбһҫбһҷ бҹ”"
msgid "HTTP error @errorcode occurred when trying to fetch @remote."
msgstr ""
"бһҖбҹҶбһ бһ»бһҹ HTTP @errorcode "
"бһ”бһ¶бһ“вҖӢбһҖбһҫбһҸбһЎбһҫбһ„вҖӢбһ“бҹ…вҖӢбһ–бҹҒбһӣвҖӢбһ–бҹ’бһҷбһ¶бһҷбһ¶бһҳвҖӢбһ‘бҹ…вҖӢбһ”бҹ’бһҡбһҳбһјбһӣвҖӢбһҷбһҖ "
"@remote бҹ”"
