<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_webform_element_ELEMENT_TYPE_alter() for our custom element.
 */
function portland_webforms_webform_element_portland_ajax_indicator_alter(array &$element, FormStateInterface $form_state, array $context) {
  $element['#attached']['library'][] = 'portland_webforms/portland_ajax_indicator';
}

/**
 * Implements hook_views_pre_render().
 */
function portland_webforms_views_pre_render(ViewExecutable $view) {
  if ($view->id() === 'council_districts' && $view->current_display === 'page_council_districts') {
    $view->element['#attached']['library'][] = 'portland_webforms/council_districts';
  }
}

