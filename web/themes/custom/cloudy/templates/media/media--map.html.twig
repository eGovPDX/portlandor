{#
/**
 * @file
 * Theme override to display a media item.
 *
 * Available variables:
 * - name: Name of the media.
 * - content: Media content.
 *
 * @see template_preprocess_media()
 *
 * @ingroup themeable
 */
#}

{% if view_mode == 'full' or view_mode == 'embedded' %}

  {% set newContent = [] %}
  {% set keyToRemove = 'image' %}
  {% if map_embeded_in_ckeditor %}
    {% set keyToRemove = 'field_geo_file' %}
  {% endif %}
  {% for key,field in content %}
    {% if key != keyToRemove %}
      {% set newContent = newContent|merge({ (key) : field}) %}
    {% endif %}
  {% endfor %}
  {% set content = newContent %}


  {# Attach libraries required to render Geo maps correctly #}
  {{ attach_library('portland_leaflet_maps/portland_leaflet_maps') }}

{% endif %}

{% embed 'media.html.twig' %}
  {% block content %}
    {{ content|without('field_alt_text', 'field_geo_file') }}
    {# leaflet-map.html.twig uses `map_id-description` for the `aria-describedby` attribute #}
    {% set alt_text_id = content.field_geo_file.0['#map_id'] ~ '-description' %}
    <span class="visually-hidden" id="{{ alt_text_id }}">{{ content.field_alt_text.0 }}</span>
    {{ content.field_geo_file }}
  {% endblock %}
{% endembed %}
