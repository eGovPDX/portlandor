{# Hide chairs and vice chairs from member list so they aren't duplicated #}
{% set chair_gids = [...element['#object'].field_chair, ...element['#object'].field_vice_chair]|map(item => item.target_id) %}
{% include "field.html.twig" with {
  items: items|filter(item => item.content['#group'].id() not in chair_gids),
} %}
