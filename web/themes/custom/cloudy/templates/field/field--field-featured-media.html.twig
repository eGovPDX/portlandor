{# true if this featured media field is owned by an entity and that entity indicated it should be decorative #}
{% set is_decorative = element['#object']
  and element['#object'].hasField('field_featured_media_decorative')
  and element['#object'].field_featured_media_decorative.value %}
{% embed "field.html.twig" %}
  {% block label %}{% endblock %}
  {% block content %}
    {% for item in items %}
      {% if is_decorative %}
        {{ item.content|add_suggestion('decorative-alt') }}
      {% else %}
        {{ item.content }}
      {% endif %}
    {% endfor %}
  {% endblock %}
{% endembed %}
