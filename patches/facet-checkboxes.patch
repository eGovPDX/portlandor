+  /**
+   * Get the active value of the dropdown.
+   *
+   * @param \Drupal\facets\Result\ResultInterface[] $results
+   *   All possible results.
+   *
+   * @return \Drupal\facets\Result\ResultInterface|null
+   *   The result that is active, or NULL if there is no active result.
+   */
+  protected function getActiveResult(array $results): ?ResultInterface {
+    $active_value = NULL;
+    foreach ($results as $result) {
+      if ($result->isActive()) {
+        return $result;
+      }
+
+      $children = $result->getChildren();
+      if (empty($children)) {
+        continue;
+      }
+
+      $active_value = $this->getActiveResult($children);
+      if (!$active_value) {
+        continue;
+      }
+
+      return $active_value;
+    }
+
+    return $active_value;
+  }
+
+  /**
+   * Builds an array of options.
+   *
+   * @param \Drupal\facets\FacetInterface $facet
+   *   The facet we need to build.
+   * @param \Drupal\facets\Result\ResultInterface[] $results
+   *   A result item.
+   *
+   * @return array
+   *   An array of options.
+   */
+  protected function buildOptions(FacetInterface $facet, array $results) {
+    $options = [];
+    $this->appendOptions($options, $facet, $results);
+    return $options;
+  }
+
+  /**
+   * Add options to the array based on the list of results.
+   *
+   * @param array $options
+   *   The list of options for the widget.
+   * @param \Drupal\facets\FacetInterface $facet
+   *   The facet we need to build.
+   * @param \Drupal\facets\Result\ResultInterface[] $results
+   *   A list of result items.
+   */
+  protected function appendOptions(array &$options, FacetInterface $facet, array $results) {
+    foreach ($results as $result) {
+      // Don't set the URL for the active result. Since we are extending the
+      // "Links" widget the URL of the active result links will cause the filter
+      // to be _disabled_. This is because the user can disable an active filter
+      // by clicking it a second time. In a dropdown this works differently: the
+      // active filter is shown highlighted and clicking it a second time will
+      // have no action. Instead the user can select the "default" option at the
+      // top of the dropdown to reset it. We set a fake URL for the active
+      // filter, so the "default" option can use the URL of the active result.
+      $urlString = $result->isActive() ? '' : $result->getUrl()->toString();
+      $options[$urlString] = $this->buildResultOptionText($result);
+
+      $children = $result->getChildren();
+      if (empty($children)) {
+        continue;
+      }
+      $this->appendOptions($options, $facet, $children);
+    }
+  }
+
+  /**
+   * Builds a facet result option text.
+   *
+   * @param \Drupal\facets\Result\ResultInterface $result
+   *   The result item.
+   *
+   * @return string
+   *   The result option text.
+   */
+  protected function buildResultOptionText(ResultInterface $result) {
+    if ($this->getConfiguration()['show_numbers']) {
+      return new FormattableMarkup(' @value (@count)', [
+        '@value' => $result->getDisplayValue(),
+        '@count' => $result->getCount(),
+      ]);
+    }
+    return $result->getDisplayValue();
+  }
+
 }
